generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int        @id @default(autoincrement())
  name        String?
  email       String     @unique
  clerkUserId String     @unique
  createdAt   DateTime   @default(now())
  endpoints   Endpoint[]
}

model Endpoint {
  id        Int        @id @default(autoincrement())
  token     String     @unique
  createdAt DateTime   @default(now())
  name      String
  provider  String?
  responses Response[]
  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name]) //uniqueness is scoped for user
  @@index([userId]) //index for faster lookups by userId
}

model Response {
  id             Int      @id @default(autoincrement())
  method         String
  headers        String
  body           String
  receivedAt     DateTime @default(now())
  endpointId     Int
  ipAddress      String?
  eventType      String?
  processingTime Int?
  signatureValid Boolean?
  statusCode     Int?
  endpoint       Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([receivedAt])
  @@index([eventType])
}
